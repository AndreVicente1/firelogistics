; Engine configuration file.
; Prefer editing through the Godot UI when possible.

config_version=5

[application]

config/name="Fire Logistics"
config/description="Simulation de gestion de crise et de lutte contre les incendies de forêt."
config/version="0.1.0"
run/main_scene="res://src/main.tscn"
config/features=PackedStringArray("4.6", "C#", "Forward Plus")

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080

[dotnet]

project/assembly_name="FireLogistics"

[rendering]

renderer/rendering_method="forward_plus"
textures/vram_compression/import_etc2_astc=true
