; Fire Logistics export presets (Godot 4.6.2 .NET).
; Copied to export_presets.cfg by export.bat if missing.

[preset.0]

name="Windows Desktop"
platform="Windows Desktop"
runnable=true
advanced_options=false
export_filter="exclude"
include_filter=""
exclude_filter="tests/*
tools/*
tools/**
.godot/mono/**
bin/**
obj/**
.cache/**
data-sources/**
assets/web/data/**
.git/*
dist/*
export/*
*.md"
export_path="dist/windows/FireLogistics.exe"
script_export_mode=2

[preset.0.options]

custom_template/debug=""
custom_template/release=""
debug/export_console_wrapper=1
binary_format/embed_pck=true
texture_format/s3tc_bptc=true
texture_format/etc2_astc=false
binary_format/architecture="x86_64"
application/product_name="Fire Logistics"
application/file_description="Fire Logistics"
application/company_name="Fire Logistics"
application/file_version="0.1.0"
application/product_version="0.1.0"
dotnet/include_scripts_content=false
dotnet/include_debug_symbols=false

