{
  "compilerOptions": {
    "target": "ES2020",
    "module": "none",
    "lib": ["ES2020", "DOM"],
    "rootDir": "ts",
    "outDir": "js",
    "allowJs": false,
    "checkJs": false,
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noEmitOnError": true,
    "removeComments": false,
    "skipLibCheck": true
  },
  "include": ["ts/**/*.ts"]
}
